<view class="page">
  <!-- 欢迎提示（未开始对话时显示） -->
  <view class="welcome" wx:if="{{messages.length === 0 && !isLoading}}">
    <view class="welcome-icon">💬</view>
    <text class="welcome-title">光伏产品经理助手</text>
    <text class="welcome-desc">Hi，我是你的专属AI助手！</text>
    <text class="welcome-hint">点击下方小图标开启对话</text>
    <view class="welcome-tags">
      <text class="tag">📊 市场分析</text>
      <text class="tag">🔬 技术对比</text>
      <text class="tag">📑 报告生成</text>
      <text class="tag">💰 成本测算</text>
      <text class="tag">📋 政策解读</text>
    </view>
  </view>

  <!-- 对话列表 -->
  <scroll-view class="msg-list" scroll-y scroll-with-animation scroll-into-view="bottom" wx:if="{{messages.length > 0 || isLoading}}">
    <view class="msg-item {{msg.role === 'user' ? 'msg-user' : 'msg-ai'}}" wx:for="{{messages}}" wx:key="index">
      <view class="msg-avatar">{{msg.role === 'user' ? '👤' : '🤖'}}</view>
      <view class="msg-content">
        <view class="msg-bubble {{msg.isError ? 'error' : ''}}">
          <text>{{msg.content}}</text>
        </view>
        <text class="msg-time">{{msg.time}}</text>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="msg-item msg-ai" wx:if="{{isLoading}}">
      <view class="msg-avatar">🤖</view>
      <view class="msg-content">
        <view class="msg-bubble loading">
          <text class="dot">思考中</text>
          <text class="dot">.</text>
          <text class="dot">.</text>
          <text class="dot">.</text>
        </view>
      </view>
    </view>

    <!-- 滚动锚点 -->
    <view id="bottom"></view>
  </scroll-view>

  <!-- 固定底部输入区 -->
  <view class="input-area">
    <input class="input-box" type="text" placeholder="输入您的问题..." value="{{inputText}}" bindinput="onInput" bindconfirm="sendMessage" disabled="{{isLoading}}" maxlength="2000" confirm-type="send" />
    <button class="send-btn" bindtap="sendMessage" disabled="{{!inputText.trim() || isLoading}}">发送</button>
  </view>
</view>
