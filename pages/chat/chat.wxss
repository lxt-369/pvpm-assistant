.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f2f5;
  overflow: hidden;
}

/* ====== 欢迎页 ====== */
.welcome {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 32px;
}
.welcome-icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #0d4a2a, #1a6b3c);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  margin-bottom: 20px;
}
.welcome-title {
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 10px;
}
.welcome-desc {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}
.welcome-hint {
  font-size: 13px;
  color: #999;
  margin-bottom: 24px;
}
.welcome-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}
.tag {
  background: #e8f5e9;
  color: #0d4a2a;
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 12px;
}

/* ====== 对话列表 ====== */
.msg-list {
  flex: 1;
  padding: 16px;
  overflow-y: scroll;
}
.msg-item {
  display: flex;
  margin-bottom: 16px;
  align-items: flex-start;
}
.msg-user {
  flex-direction: row-reverse;
}
.msg-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  background: #f5f5f5;
}
.msg-content {
  max-width: 75%;
  margin: 0 10px;
}
.msg-bubble {
  padding: 12px 16px;
  border-radius: 16px;
  font-size: 14px;
  line-height: 1.6;
  color: #333;
  word-break: break-word;
  white-space: pre-wrap;
}
.msg-user .msg-bubble {
  background: #95ec69;
  border-bottom-right-radius: 4px;
}
.msg-ai .msg-bubble {
  background: #fff;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}
.msg-bubble.error {
  background: #fff3f3;
  color: #e74c3c;
}
.msg-time {
  font-size: 11px;
  color: #bbb;
  margin-top: 4px;
  display: block;
}

/* ====== 加载动画 ====== */
.loading {
  display: flex;
  align-items: center;
  gap: 2px;
}
.dot {
  animation: blink 1.4s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
.dot:nth-child(4) { animation-delay: 0.6s; }
@keyframes blink {
  0%, 80%, 100% { opacity: 0; }
  40% { opacity: 1; }
}

/* ====== 输入区 ====== */
.input-area {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid #eee;
  flex-shrink: 0;
}
.input-box {
  flex: 1;
  height: 40px;
  background: #f5f5f5;
  border-radius: 20px;
  padding: 0 16px;
  font-size: 14px;
}
.send-btn {
  margin-left: 10px;
  width: 64px;
  height: 36px;
  line-height: 36px;
  background: linear-gradient(135deg, #0d4a2a, #1a6b3c);
  color: #fff;
  border-radius: 18px;
  font-size: 14px;
  text-align: center;
  flex-shrink: 0;
  padding: 0;
}
.send-btn[disabled] {
  opacity: 0.5;
}
